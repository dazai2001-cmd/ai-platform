# Copy to .env.production and replace every required value before starting.
# Keep this file out of source control after copying; never commit real secrets.

# Published images. Omit these to build the images locally.
# Prefer the immutable full-commit tags printed by the release workflow.
# API_IMAGE=ghcr.io/your-github-user/ai-platform-api:sha-<full-commit-sha>
# FRONTEND_IMAGE=ghcr.io/your-github-user/ai-platform-frontend:sha-<full-commit-sha>

# The frontend is bound to loopback for a host-level HTTPS reverse proxy.
BIND_ADDRESS=127.0.0.1
APP_PORT=3000
APP_PUBLIC_URL=https://ai.example.com
CORS_ORIGINS=https://ai.example.com

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Optional defense in depth for the internal API. The Next.js server injects it;
# it is never compiled into public browser JavaScript.
API_AUTH_TOKEN=

# Required shared application database. Prefer Supabase's session-pooler
# connection URL (port 5432) for a persistent IPv4-only Render service. Keep
# application tables in a private schema that is not exposed through the Data API.
DATABASE_URL=
DATABASE_SCHEMA=app_private
DATABASE_SSLMODE=require
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=5

# Production account verification is mandatory.
RESEND_API_KEY=
EMAIL_FROM=AI Platform <verify@ai.example.com>

# Cloud is the production default. Configure at least one provider.
AI_RUNTIME=cloud
GEMINI_API_KEY=
GEMINI_MODELS=gemini-3.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODELS=

# This quota-free provider avoids both PyTorch memory pressure and API throttling.
EMBEDDING_PROVIDER=hashing
GEMINI_EMBED_MODEL=gemini-embedding-2
EMBED_DIM=1024
EMBED_BATCH_SIZE=100
EMBED_MAX_RETRIES=4
EMBED_RETRY_BASE_SECONDS=1
EMBED_RETRY_MAX_SECONDS=60

# The documented TLS proxy -> Next.js -> API topology has one trusted XFF hop.
# Change this only when your topology differs, and make the edge proxy overwrite
# (not append) client-supplied X-Forwarded-For headers.
TRUST_PROXY_HOPS=1

# Optional job-search providers.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=
