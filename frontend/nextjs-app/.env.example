# Keep empty in production so browser requests use the same-origin Next proxy.
# Local development may point directly at the API when API_AUTH_TOKEN is unset.
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
API_INTERNAL_URL=http://127.0.0.1:5000
# Server-only boundary credential used by the Next proxy; never NEXT_PUBLIC_*.
API_AUTH_TOKEN=
NEXT_PUBLIC_AUTH_REQUIRED=false
