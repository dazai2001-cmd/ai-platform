# Ollama (already installed locally)
AI_RUNTIME=local
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=180
LLM_MAX_TOKENS=768

# Cloud LLMs. Use AI_RUNTIME=cloud on Render.
GEMINI_API_KEY=
GEMINI_MODELS=gemini-3.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODELS=
CLOUD_LLM_TIMEOUT_SECONDS=45

# Model routing. The router classifies the user query, then chooses from this map.
TASK_MODELS_JSON={"rag":"qwen3:8b","bi":"qwen3:8b","memory":"llama3:latest","general":"mistral:latest"}
CLOUD_TASK_MODELS_JSON={}
ROUTER_MODEL=qwen3:8b
LOCAL_ALLOWED_MODELS=qwen3:8b,llama3:latest,mistral:latest

# Embeddings
EMBEDDING_PROVIDER=local
EMBED_MODEL=all-MiniLM-L6-v2
GEMINI_EMBED_MODEL=gemini-embedding-2
EMBED_DIM=384
EMBED_BATCH_SIZE=100
EMBED_MAX_RETRIES=4
EMBED_RETRY_BASE_SECONDS=1
EMBED_RETRY_MAX_SECONDS=60

# Redis memory
REDIS_URL=redis://redis:6379

# Application database. Leave blank for local SQLite. In cloud deployments,
# use the Supabase PostgreSQL connection/pooler URL (including its password).
DATABASE_URL=
DATABASE_SCHEMA=app_private
DATABASE_SSLMODE=prefer
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_POOL_MIN_SIZE=1
DATABASE_POOL_MAX_SIZE=5

# RAG settings
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=5
MAX_DOCUMENTS_PER_USER=100
MAX_TEXT_INGEST_CHARS=200000
MAX_SOURCE_CHARS=512
MAX_CHUNKS_PER_DOCUMENT=2000
MAX_CHUNKS_PER_USER=20000
MAX_PDF_PAGES=250
MAX_CV_UPLOAD_BYTES=10485760
MAX_CV_PDF_PAGES=25
MAX_CV_DOCX_ARCHIVE_FILES=250
MAX_CV_DOCX_UNCOMPRESSED_BYTES=26214400
MAX_CV_DOCX_COMPRESSION_RATIO=100

# App
APP_ENV=development
DEBUG=false
PORT=5000
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_PUBLIC_URL=http://127.0.0.1:3000
AUTH_REQUIRED=false
AUTH_SESSION_DAYS=14
AUTH_VERIFICATION_HOURS=24
AUTH_COOKIE_NAME=ai_platform_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
RESEND_API_KEY=
EMAIL_FROM=AI Platform <onboarding@resend.dev>
SEND_VERIFICATION_EMAILS=false

# Request and abuse controls. Use redis://... storage for multi-instance cloud deployments.
MAX_UPLOAD_BYTES=52428800
MAX_JSON_BYTES=1048576
MAX_PROMPT_CHARS=12000
MAX_DATASET_ROWS=100000
MAX_DATASET_COLUMNS=200
MAX_DATASET_UPLOAD_BYTES=26214400
MAX_DATASET_MEMORY_BYTES=134217728
MAX_DATASET_MEMORY_BYTES_PER_USER=268435456
MAX_DATASETS_PER_USER=10
MAX_DATASET_STORAGE_BYTES_PER_USER=104857600
MAX_EXCEL_UNCOMPRESSED_BYTES=104857600
MAX_EXCEL_ARCHIVE_FILES=1000
MAX_EXCEL_COMPRESSION_RATIO=100
BI_SQL_TIMEOUT_MS=1000
BI_MAX_SQL_CHARS=10000
BI_MAX_RESULT_CELL_BYTES=1048576
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_AUTH=5 per minute
RATE_LIMIT_AI=10 per minute
RATE_LIMIT_UPLOAD=5 per minute
# Set this to the exact number of trusted reverse-proxy hops; keep 0 otherwise.
TRUST_PROXY_HOPS=0
ANALYTICS_STORE_QUERY_TEXT=true
ANALYTICS_MAX_FILE_BYTES=10485760
ANALYTICS_RETENTION_DAYS=30

# Career search providers
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=
CAREER_CLOUD_MAX_SCORE_BATCH_JOBS=10
CAREER_CLOUD_DAILY_SCORE_LIMIT=25
CAREER_CLOUD_DAILY_PACK_LIMIT=5

# Optional server-to-server boundary token. In browser deployments keep the
# API behind the same-origin Next proxy, which injects this server-side.
# Never expose this value through a NEXT_PUBLIC_* variable.
API_AUTH_TOKEN=

# Limits / storage
MAX_URL_INGEST_BYTES=5242880
BI_MANIFEST_PATH=data/processed/bi_datasets.json
