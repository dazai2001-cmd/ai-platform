# Ollama (already installed locally)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=180
LLM_MAX_TOKENS=768

# Model routing. The router classifies the user query, then chooses from this map.
TASK_MODELS_JSON={"rag":"qwen3:8b","bi":"qwen3:8b","memory":"llama3:latest","general":"mistral:latest"}
ROUTER_MODEL=qwen3:8b

# Optional OpenAI-compatible cloud model provider.
# ZenMux example:
OPENAI_COMPAT_BASE_URL=https://zenmux.ai/api/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODELS=z-ai/glm-5.2-free
OPENAI_COMPAT_TIMEOUT_SECONDS=180
OPENAI_COMPAT_MIN_TOKENS=4096
OPENAI_COMPAT_FALLBACK_MODEL=qwen3:8b
OPENAI_COMPAT_COOLDOWN_SECONDS=300

# Embeddings
EMBED_MODEL=all-MiniLM-L6-v2

# Redis memory
REDIS_URL=redis://redis:6379

# RAG settings
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=5

# App
DEBUG=false
PORT=5000
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional. If set, clients must send X-API-Token with this value.
API_AUTH_TOKEN=

# Optional UK job search providers.
# Adzuna: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Reed: https://www.reed.co.uk/developers/jobseeker
REED_API_KEY=

# Limits / storage
MAX_URL_INGEST_BYTES=5242880
BI_MANIFEST_PATH=data/processed/bi_datasets.json
